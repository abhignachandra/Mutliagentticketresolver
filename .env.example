# Copy this file to `.env` and fill in the values.
# Do NOT commit the real .env to git.

# ---- Azure OpenAI ---------------------------------------------------------
AZURE_OPENAI_DEPLOYMENT=gpt-4o
AZURE_OPENAI_API_KEY=your_azure_openai_key_here
AZURE_OPENAI_ENDPOINT=https://your-resource-name.cognitiveservices.azure.com/
AZURE_OPENAI_API_VERSION=2024-12-01-preview

# ---- Azure AI Search (knowledge base) -------------------------------------
AZURE_SEARCH_ENDPOINT=https://your-search.search.windows.net
AZURE_SEARCH_KEY=your-search-admin-key
AZURE_SEARCH_INDEX=it-knowledge-base

# ---- SMTP (Gmail example) -------------------------------------------------
SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587
SENDER_EMAIL=your-bot-account@gmail.com
# Use a Gmail App Password (16 chars). Generated at myaccount.google.com/apppasswords.
SENDER_PASSWORD=xxxxxxxxxxxxxxxx
SUPPORT_EMAIL=it-support@yourcompany.com
